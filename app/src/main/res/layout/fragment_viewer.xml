<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".ViewerFragment">

    <!-- TOP BAR -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnToggleDxf"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_button"
            android:src="@drawable/ic_dxf_toggle"
            app:tint="@color/accent_orange"/>

        <TextView
            android:id="@+id/welcomeText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:paddingStart="12dp"
            android:visibility="gone"/>

        <ImageButton
            android:id="@+id/btnWhatsapp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_button"
            android:src="@drawable/ic_whatsapp"
            app:tint="@color/accent_orange"/>
    </LinearLayout>

    <!-- DISPLAY TOOLBAR العلوي - سايبه زي ما هو 46dp -->
    <LinearLayout
        android:id="@+id/displayToolbar"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <ToggleButton
            android:id="@+id/btnLightToggle"
            android:layout_width="0dp" android:layout_height="34dp" android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:textOn="" android:textOff=""
            android:background="@drawable/bg_toggle_button"
            android:drawableTop="@drawable/ic_light_bulb"
            app:drawableTint="@color/accent_orange" />

        <Button
            android:id="@+id/btnOpenFile"
            android:layout_width="0dp" android:layout_height="34dp" android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:text=""
            android:background="@drawable/bg_toggle_button"
            android:drawableTop="@drawable/ic_folder"
            app:drawableTint="@color/accent_orange" />

        <Button
            android:id="@+id/btnUnit"
            android:layout_width="0dp" android:layout_height="34dp" android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:text="@string/unit_mm"
            android:textSize="12sp"
            android:background="@drawable/bg_toggle_button"
            android:textColor="@color/accent_orange" />

        <Button
            android:id="@+id/btnMaterial"
            android:layout_width="0dp" android:layout_height="34dp" android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:text=""
            android:background="@drawable/bg_toggle_button"
            android:drawableTop="@drawable/ic_material_palette"
            app:drawableTint="@color/accent_orange" />

        <ToggleButton
            android:id="@+id/btnWireframe"
            android:layout_width="0dp" android:layout_height="34dp" android:layout_weight="1"
            android:textOn="" android:textOff=""
            android:background="@drawable/bg_toggle_button"
            android:drawableTop="@drawable/ic_wireframe_glyph"
            app:drawableTint="@color/accent_orange" />
    </LinearLayout>

    <!-- GL VIEWER 3D -->
    <com.amr3d.preview.pro.GLViewerView
        android:id="@+id/glViewerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/displayToolbar"
        app:layout_constraintBottom_toTopOf="@id/bottomToolbar" />

    <!-- DXF VIEWER 2D -->
    <com.amr3d.preview.pro.DXF2DView
        android:id="@+id/dxf2DView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/displayToolbar"
        app:layout_constraintBottom_toTopOf="@id/bottomToolbar" />

    <!-- EMPTY STATE -->
    <TextView
        android:id="@+id/emptyStateText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/empty_state"
        android:textColor="@color/gray"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- WELCOME OVERLAY -->
    <TextView
        android:id="@+id/welcomeOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textColor="@color/accent_orange"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- LOADING -->
    <LinearLayout
        android:id="@+id/loadingContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomToolbar">

        <ProgressBar
            android:id="@+id/loadingProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp" />

        <TextView
            android:id="@+id/loadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/white" />
    </LinearLayout>

    <!-- BOTTOM TOOLBAR السفلي - ده اللي اتعدل 54dp -->
    <LinearLayout
        android:id="@+id/bottomToolbar"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ToggleButton
            android:id="@+id/btnBoundingBox"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:textOn="" android:textOff=""
            android:background="@drawable/bg_toggle_button"
            android:drawableTop="@drawable/ic_cube"
            app:iconSize="24dp"
            android:paddingTop="6dp" android:paddingBottom="6dp"
            app:drawableTint="@color/accent_orange" />

        <Button
            android:id="@+id/btnResetView"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:text=""
            android:background="@drawable/bg_toggle_button"
            android:drawableTop="@drawable/ic_reset_view"
            app:iconSize="24dp"
            android:paddingTop="6dp" android:paddingBottom="6dp"
            app:drawableTint="@color/accent_orange" />

        <Button
            android:id="@+id/btnInspect"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:text=""
            android:background="@drawable/bg_toggle_button"
            android:drawableTop="@drawable/ic_inspect"
            app:iconSize="24dp"
            android:paddingTop="6dp" android:paddingBottom="6dp"
            app:drawableTint="@color/accent_orange" />

        <ToggleButton
            android:id="@+id/btnMeasureTool"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:textOn="" android:textOff=""
            android:background="@drawable/bg_toggle_button"
            android:drawableTop="@drawable/ic_measure_ruler"
            app:iconSize="24dp"
            android:paddingTop="6dp" android:paddingBottom="6dp"
            app:drawableTint="@color/accent_orange" />

        <ToggleButton
            android:id="@+id/btnAutoRotate"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:textOn="" android:textOff=""
            android:background="@drawable/bg_toggle_button"
            android:drawableTop="@drawable/ic_rotate"
            app:iconSize="24dp"
            android:paddingTop="6dp" android:paddingBottom="6dp"
            app:drawableTint="@color/accent_orange" />
    </LinearLayout>

    <!-- MEASUREMENT CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/measurementCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomToolbar"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp">
        <TextView
            android:id="@+id/measurementText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textColor="@color/white"/>
    </androidx.cardview.widget.CardView>

    <!-- INSPECTION CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/inspectionCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomToolbar"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="16dp">
        <TextView
            android:id="@+id/inspectionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textColor="@color/white"/>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
